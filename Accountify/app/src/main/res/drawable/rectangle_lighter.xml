<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Define the stroke (the gray line) -->
    <stroke
        android:width="1dp"
        android:color="#000000" />

    <!-- Define the corners to make them curved -->
    <corners
        android:radius="6dp" />

    <!-- Define the solid color for the background.
         Setting it to transparent will make it have "no background". -->
    <solid
        android:color="@android:color/transparent" />

</shape>

