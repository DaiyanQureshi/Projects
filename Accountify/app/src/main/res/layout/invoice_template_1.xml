<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

  <LinearLayout
      android:id="@+id/invoice_printable_area"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical">

    <LinearLayout
        android:id="@+id/master_header_layout"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:layout_marginBottom="2dp"
        android:background="#884CA2"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

      <FrameLayout
          android:layout_width="60dp"
          android:layout_height="60dp"
          android:layout_gravity="center_vertical"
          android:layout_marginEnd="10dp"
          android:background="#FFFFFF"
          android:padding="3dp"
          android:visibility="gone">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:src="@android:drawable/ic_menu_gallery" />
      </FrameLayout>

      <LinearLayout
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_gravity="center_vertical"
          android:layout_weight="1"
          android:gravity="center_vertical"
          android:orientation="vertical">

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="1dp"
            android:includeFontPadding="false"
            android:text="Business Name"
            android:textColor="#E4E4A0"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/mobile_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="Mobile: +91 99999 88888"
            android:textColor="#E4E4A0"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/email_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="Email: info@business.com"
            android:textColor="#E4E4A0"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/website"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:includeFontPadding="false"
            android:text="Website: www.business.name.com"
            android:textColor="#E4E4A0"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/address"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="Address Line 1"

            android:textColor="#E4E4A0"
            android:textSize="9sp" />
      </LinearLayout>

      <LinearLayout
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_gravity="center_vertical"
          android:layout_marginEnd="21dp"
          android:gravity="center_vertical"
          android:orientation="horizontal">

        <ImageView
            android:id="@+id/btnShareIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_share"
            app:tint="#E4E4A0" />

        <TextView
            android:id="@+id/document_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="INVOICE"
            android:textColor="#E4E4A0"
            android:textSize="22sp"
            android:textStyle="bold" />
      </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/trader_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="6dp"
        android:paddingEnd="12dp">

      <LinearLayout
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="Bill To"
            android:textColor="#000"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/trader_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="Client Name"
            android:textColor="#000"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/trader_contect_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="Contact (Opt)"
            android:textColor="#000"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/trader_address"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="Address Line 1"
            android:textColor="#000"
            android:textSize="9sp" />
      </LinearLayout>

      <LinearLayout
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:orientation="vertical"
          android:paddingStart="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="Shipping Address"
            android:textColor="#000"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/contect_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="Contact Name"
            android:textColor="#000"
            android:textSize="9sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="Shipping Addr 1"
            android:textColor="#000"
            android:textSize="9sp" />
      </LinearLayout>

      <TableLayout
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="0.9"
          android:stretchColumns="1">

        <TableRow>

          <TextView
              android:includeFontPadding="false"
              android:paddingEnd="4dp"
              android:text="Inv No:"
              android:textColor="#000"
              android:textSize="9sp"
              android:textStyle="bold" />

          <TextView
              android:id="@+id/document_name"
              android:gravity="end"
              android:includeFontPadding="false"
              android:text="INV-001"
              android:textColor="#000"
              android:textSize="9sp" />
        </TableRow>

        <TableRow>

          <TextView
              android:includeFontPadding="false"
              android:text="Date:"
              android:textColor="#000"
              android:textSize="9sp" />

          <TextView
              android:id="@+id/trade_date"
              android:gravity="end"
              android:includeFontPadding="false"
              android:text="12-10-25"
              android:textColor="#000"
              android:textSize="9sp" />
        </TableRow>

        <TableRow>

          <TextView
              android:includeFontPadding="false"
              android:text="Due:"
              android:textColor="#000"
              android:textSize="9sp" />

          <TextView
              android:id="@+id/due_date"
              android:gravity="end"
              android:includeFontPadding="false"
              android:text="20-10-25"
              android:textColor="#000"
              android:textSize="9sp" />
        </TableRow>

        <TableRow>

          <TextView
              android:includeFontPadding="false"
              android:text="PO No:"
              android:textColor="#000"
              android:textSize="9sp" />

          <TextView
              android:id="@+id/po_number"
              android:gravity="end"
              android:includeFontPadding="false"
              android:text="PO-001"
              android:textColor="#000"
              android:textSize="9sp" />
        </TableRow>
      </TableLayout>
    </LinearLayout>

    <TableLayout
        android:id="@+id/tableItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="12dp">

      <TableRow
          android:background="#E4E4A0"
          android:paddingStart="6dp"
          android:paddingTop="1dp"
          android:paddingEnd="6dp"
          android:paddingBottom="1dp"
          android:weightSum="10">

        <TextView
            android:id="@+id/serial_number"
            android:layout_weight="0.8"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="Sl."
            android:textColor="#884CA2"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/description"
            android:layout_weight="1.5"
            android:gravity="start"
            android:includeFontPadding="false"
            android:text="Description"
            android:textColor="#884CA2"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:layout_weight="2.57"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="Date"
            android:textColor="#884CA2"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/avg_rate"
            android:layout_weight="1.7"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="Qty"
            android:textColor="#884CA2"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/rate"
            android:layout_weight="1.7"
            android:gravity="end"
            android:includeFontPadding="false"
            android:text="Rate"
            android:textColor="#884CA2"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/amount"
            android:layout_weight="1.7"
            android:gravity="end"
            android:includeFontPadding="false"
            android:text="Amount"
            android:textColor="#884CA2"
            android:textSize="10sp"
            android:textStyle="bold" />
      </TableRow>

      <View
          android:layout_height="0.5dp"
          android:background="#CCCCCC"
          android:visibility="gone" />

      <TableRow
          android:paddingStart="6dp"
          android:paddingTop="1dp"
          android:paddingEnd="6dp"
          android:paddingBottom="1dp"
          android:visibility="gone"
          android:weightSum="10">

        <TextView
            android:layout_weight="0.8"
            android:gravity="center"
            android:text="1"
            android:textColor="#000"
            android:textSize="9sp" />

        <TextView
            android:layout_weight="2.4"
            android:gravity="start"
            android:text="Item 1"
            android:textColor="#000"
            android:textSize="9sp" />

        <TextView
            android:layout_weight="1.7"
            android:gravity="center"
            android:text="Date"
            android:textSize="9sp" />

        <TextView
            android:layout_weight="1.7"
            android:gravity="center"
            android:text=""
            android:textSize="9sp" />

        <TextView
            android:layout_weight="1.7"
            android:gravity="end"
            android:text=""
            android:textSize="9sp" />

        <TextView
            android:layout_weight="1.7"
            android:gravity="end"
            android:text="0.00"
            android:textColor="#000"
            android:textSize="9sp" />
      </TableRow>

      <TableRow
          android:paddingStart="6dp"
          android:paddingTop="1dp"
          android:paddingEnd="6dp"
          android:paddingBottom="1dp"
          android:visibility="gone"
          android:weightSum="10">

        <TextView
            android:layout_weight="0.8"
            android:gravity="center"
            android:text="2"
            android:textColor="#000"
            android:textSize="9sp" />

        <TextView
            android:layout_weight="2.4"
            android:gravity="start"
            android:text="Item 2"
            android:textColor="#000"
            android:textSize="9sp" />

        <TextView
            android:layout_weight="1.7"
            android:gravity="center"
            android:text="Date"
            android:textSize="9sp" />

        <TextView
            android:layout_weight="1.7"
            android:gravity="center"
            android:text=""
            android:textSize="9sp" />

        <TextView
            android:layout_weight="1.7"
            android:gravity="end"
            android:text=""
            android:textSize="9sp" />

        <TextView
            android:layout_weight="1.7"
            android:gravity="end"
            android:text="0.00"
            android:textColor="#000"
            android:textSize="9sp" />
      </TableRow>

      <TableRow
          android:paddingStart="6dp"
          android:paddingTop="1dp"
          android:paddingEnd="6dp"
          android:paddingBottom="1dp"
          android:visibility="gone"
          android:weightSum="10">

        <TextView
            android:layout_weight="0.8"
            android:gravity="center"
            android:text="3"
            android:textColor="#000"
            android:textSize="9sp" />

        <TextView
            android:layout_weight="2.4"
            android:gravity="start"
            android:text="Item 3"
            android:textColor="#000"
            android:textSize="9sp" />

        <TextView
            android:layout_weight="1.7"
            android:gravity="center"
            android:text="Date"
            android:textSize="9sp" />

        <TextView
            android:layout_weight="1.7"
            android:gravity="center"
            android:text=""
            android:textSize="9sp" />

        <TextView
            android:layout_weight="1.7"
            android:gravity="end"
            android:text=""
            android:textSize="9sp" />

        <TextView
            android:layout_weight="1.7"
            android:gravity="end"
            android:text="0.00"
            android:textColor="#000"
            android:textSize="9sp" />
      </TableRow>

      <View
          android:layout_height="0.5dp"
          android:background="#CCCCCC" />
    </TableLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:padding="8dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

      <TextView
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1.6"
          android:includeFontPadding="false"
          android:text="Thanks for your business"
          android:textColor="#000"
          android:textSize="10sp"
          android:textStyle="bold" />

      <TableLayout
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:stretchColumns="1">

        <TableRow android:paddingBottom="1dp">

          <TextView
              android:includeFontPadding="false"
              android:paddingStart="6dp"
              android:text="Subtotal"
              android:textColor="#000"
              android:textSize="9sp"
              android:textStyle="bold" />

          <TextView
              android:id="@+id/subtotal"
              android:gravity="end"
              android:includeFontPadding="false"
              android:paddingEnd="6dp"
              android:text="0.00"
              android:textColor="#000"
              android:textSize="9sp"
              android:textStyle="bold" />
        </TableRow>

        <TableRow android:paddingBottom="1dp">

          <TextView
              android:id="@+id/discount_in_percent"
              android:includeFontPadding="false"
              android:paddingStart="6dp"
              android:text="Discount (%)"
              android:textColor="#000"
              android:textSize="9sp"
              android:textStyle="bold" />

          <TextView
              android:id="@+id/discount_in_rupee"
              android:gravity="end"
              android:includeFontPadding="false"
              android:paddingEnd="6dp"
              android:text="0.00"
              android:textColor="#000"
              android:textSize="9sp" />
        </TableRow>

        <TableRow android:paddingBottom="1dp">

          <TextView
              android:id="@+id/tax_in_percent"
              android:includeFontPadding="false"
              android:paddingStart="6dp"
              android:text="Tax Rate (%)"
              android:textColor="#000"
              android:textSize="9sp"
              android:textStyle="bold" />

          <TextView
              android:id="@+id/tax_in_rupee"
              android:gravity="end"
              android:includeFontPadding="false"
              android:paddingEnd="6dp"
              android:text="0.00"
              android:textColor="#000"
              android:textSize="9sp" />
        </TableRow>

        <View
            android:layout_height="0.5dp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp"
            android:background="#CCCCCC" />

        <TableRow>

          <TextView
              android:includeFontPadding="false"
              android:paddingStart="6dp"
              android:text="Total"
              android:textColor="#000"
              android:textSize="11sp"
              android:textStyle="bold" />

          <TextView
              android:id="@+id/total"
              android:gravity="end"
              android:includeFontPadding="false"
              android:paddingEnd="6dp"
              android:text="0.00"
              android:textColor="#000"
              android:textSize="11sp"
              android:textStyle="bold" />
        </TableRow>
      </TableLayout>
    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="15dp" />

    <LinearLayout
        android:id="@+id/footer_payment_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:padding="8dp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp">

      <LinearLayout
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1.2"
          android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="Payment Instructions"
            android:textColor="#884CA2"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="Add payment instructions here,\ne.g. Bank, PayPal..."
            android:textColor="#555"
            android:textSize="9sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:includeFontPadding="false"
            android:text="Add terms here\nAdd notes here"
            android:textColor="#555"
            android:textSize="9sp" />
      </LinearLayout>

      <LinearLayout
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="0.8"
          android:gravity="end"
          android:orientation="vertical">

        <LinearLayout
            android:id="@+id/signature_layout"
            android:layout_width="110dp"
            android:layout_height="30dp"
            android:background="@drawable/rect_border"
            android:gravity="center">

          <ImageView
              android:id="@+id/signanture_image"
              android:layout_width="110dp"
              android:layout_height="30dp"
              android:visibility="gone"
              tools:srcCompat="@tools:sample/avatars" />

          <TextView
              android:id="@+id/signanture_text"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:includeFontPadding="false"
              android:text="Signature"
              android:textColor="#AAAAAA"
              android:textSize="9sp" />

        </LinearLayout>

        <TextView
            android:layout_width="110dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="Authorized Signatory"
            android:textColor="#000"
            android:textSize="9sp"
            android:textStyle="bold" />

      </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:layout_marginTop="100dp"
        android:background="#884CA2" />

  </LinearLayout>
</ScrollView>