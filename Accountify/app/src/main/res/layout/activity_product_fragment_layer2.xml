<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F7"
    tools:context=".fragment_product.ProductFragment_Layer_2">

    <FrameLayout
        android:id="@+id/frameLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="253dp"
        android:background="@drawable/header_background"
        android:elevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0">


        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/dp"
                android:layout_width="143dp"
                android:layout_height="165dp"
                android:foregroundGravity="center_vertical"
                android:padding="2dp"
                android:scaleType="centerCrop"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.0"
                app:shapeAppearanceOverlay="@style/Circular"
                app:srcCompat="@drawable/product_icon" />

            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:gravity="center_vertical"
                android:shadowColor="#404040"
                android:text="Dairy Milk"
                android:textAppearance="@style/TextAppearance.AppCompat.Medium"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@+id/total_quantity_text"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toEndOf="@+id/dp"
                app:layout_constraintTop_toTopOf="@+id/dp"
                app:layout_constraintVertical_bias=".14"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/total_quantity_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Quantity: "
                android:textColor="#817E7E"
                android:textSize="15sp"
                app:layout_constraintBottom_toBottomOf="@+id/dp"
                app:layout_constraintEnd_toEndOf="@+id/title"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="@+id/title"
                app:layout_constraintTop_toBottomOf="@+id/title"
                app:layout_constraintVertical_bias="0.0" />

            <TextView
                android:id="@+id/total_quantity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:text="50 Cts"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintStart_toStartOf="@+id/title"
                app:layout_constraintTop_toBottomOf="@+id/title"
                app:layout_constraintVertical_bias="0.0" />

            <TextView
                android:id="@+id/avg_rate_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Average Rate: "
                android:textColor="#817E7E"
                android:textSize="15sp"
                app:layout_constraintBottom_toBottomOf="@+id/dp"
                app:layout_constraintEnd_toEndOf="@+id/title"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="@+id/title"
                app:layout_constraintTop_toBottomOf="@+id/total_quantity_text"
                app:layout_constraintVertical_bias="0.10" />

            <TextView
                android:id="@+id/avg_rate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5000 ₹/Cts"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/dp"
                app:layout_constraintEnd_toEndOf="@+id/total_quantity"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintStart_toStartOf="@+id/title"
                app:layout_constraintTop_toTopOf="@+id/avg_rate_text"
                app:layout_constraintVertical_bias="0.0" />

            <TextView
                android:id="@+id/total_amount_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:foregroundGravity="left"
                android:gravity="left"
                android:text="Total Purchase: "
                android:textColor="#817E7E"
                android:textSize="15sp"
                app:layout_constraintBottom_toBottomOf="@+id/dp"
                app:layout_constraintEnd_toEndOf="@+id/title"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="@+id/avg_rate_text"
                app:layout_constraintTop_toBottomOf="@+id/avg_rate_text"
                app:layout_constraintVertical_bias="0.13" />

            <TextView
                android:id="@+id/total_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="right"
                android:text="₹ 9,989.00"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/total_amount_text"
                app:layout_constraintEnd_toEndOf="@+id/avg_rate"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintStart_toEndOf="@+id/total_amount_text"
                app:layout_constraintTop_toTopOf="@+id/total_amount_text" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#D5EDDC"
                app:cardElevation="0dp"
                app:layout_constraintBottom_toTopOf="@+id/total_amount_text"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.0"
                app:shapeAppearanceOverlay="@style/CustomCardShape"
                app:strokeWidth="0dp" />


        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/layer_2_recycle_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="80dp"
        android:paddingBottom="200dp"
        android:radius="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/filter_background"
        app:layout_constraintVertical_bias="0.0" />

    <FrameLayout
        android:id="@+id/filter_background"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:elevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/frameLayout"
        app:layout_constraintVertical_bias="0.0">


        <TextView
            android:id="@+id/history"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="left"
            android:layout_marginLeft="17.5dp"
            android:layout_marginTop="17.3dp"
            android:layout_weight="1"
            android:gravity="start"
            android:text="History:"
            android:textColor="#000000"
            android:textSize="13sp"
            android:textStyle="bold" />


        <TextView
            android:id="@+id/purchase"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="left"
            android:layout_marginStart="74.5dp"
            android:layout_marginTop="17.3dp"
            android:layout_weight="1"
            android:gravity="start"
            android:text="Purchase"
            android:textColor="#304FFE"
            android:textSize="13sp"
            android:textStyle="bold" />

        <View
            android:id="@+id/purchase_view"
            android:layout_width="55.9dp"
            android:layout_height="2dp"
            android:layout_gravity="bottom|left"
            android:layout_marginLeft="73.1dp"
            android:layout_marginBottom="2dp"
            android:background="#304FFE" />

        <TextView
            android:id="@+id/Sale"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="left"
            android:layout_marginLeft="142.59999dp"
            android:layout_marginTop="17.3dp"
            android:layout_weight="1"
            android:gravity="start"
            android:text="Sale"
            android:textColor="#7F8081"
            android:textSize="13sp"
            android:textStyle="bold" />

        <View
            android:id="@+id/sale_view"
            android:layout_width="26.5dp"
            android:layout_height="2dp"
            android:layout_gravity="bottom|left"
            android:layout_marginLeft="142.5dp"
            android:layout_marginBottom="2dp"
            android:background="#304FFE" />


        <ImageView
            android:id="@+id/three_dots"
            android:layout_width="37dp"
            android:layout_height="24dp"
            android:layout_marginTop="19dp"
            android:elevation="7dp"
            android:onClick="threedots"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/header_background"
            app:srcCompat="@drawable/three_dots" />

        <SearchView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:layout_marginEnd="37dp"
            android:elevation="7dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/header_background" />


    </FrameLayout>


</androidx.constraintlayout.widget.ConstraintLayout>