<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F7"
    tools:context=".new_purchase.add_item_to_purchase">




    <ScrollView
        android:id="@+id/scrollView2"
        android:layout_width="0dp"
        android:layout_height="800dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/home_image"
            android:layout_width="match_parent"
            android:layout_height="400dp">

            <FrameLayout
                android:id="@+id/header_background"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:background="#FFFFFF"
                android:elevation="6dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.0">

                <ImageView
                    android:id="@+id/image_path"
                    android:layout_width="44dp"
                    android:layout_height="30dp"
                    android:layout_gravity="right|center_vertical"
                    android:layout_marginEnd="16dp"
                    android:foregroundGravity="right"

                    app:srcCompat="@android:drawable/ic_menu_camera" />

                <ImageView
                    android:id="@+id/back"
                    android:layout_width="41dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="11dp"
                    app:srcCompat="?attr/homeAsUpIndicator" />

                <TextView
                    android:id="@+id/title"
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:layout_gravity="top|left"
                    android:layout_marginStart="62dp"
                    android:layout_marginTop="6dp"
                    android:gravity="top"
                    android:text="Add item to Purchase"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/business_name"
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:layout_gravity="top|left"
                    android:layout_marginStart="62dp"
                    android:layout_marginTop="31dp"
                    android:text="Business Name"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </FrameLayout>

            <FrameLayout
                android:id="@+id/data_input_panel_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp"
                android:background="@drawable/white_sqaure_round"
                android:elevation="6dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/header_background"
                app:layout_constraintVertical_bias="0.0">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/stock_item_recycle_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="16dp"
                    android:layout_marginTop="88dp"
                    android:layout_marginRight="16.1dp"
                    android:layout_marginBottom="16dp"
                    android:background="@color/white"
                    android:elevation="8dp"
                    android:radius="8dp"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="1.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="1.0" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="9dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                       ></LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/customer_name_input_layout"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="16dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginRight="16dp"
                        android:hint="Supplier*"
                        android:visibility="gone"
                        app:boxStrokeColor="@color/input_field_colors"
                        app:hintTextColor="@color/input_field_colors">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/person_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/item_name_input_layout"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="16dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginRight="16dp"
                        android:hint="Item Name*"
                        app:boxStrokeColor="@color/input_field_colors"
                        app:hintTextColor="@color/input_field_colors">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/item_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/quantity_input_layout"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginLeft="16dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginRight="8dp"
                            android:layout_weight="1"
                            android:hint="Quantity*"
                            app:boxStrokeColor="@color/input_field_colors"
                            app:hintTextColor="@color/input_field_colors">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/avg_rate"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/unit_layout"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginLeft="8dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginRight="16dp"
                            android:layout_weight="1"
                            android:hint="Unit"
                            app:boxStrokeColor="@color/input_field_colors"
                            app:hintTextColor="@color/input_field_colors"
                            app:layout_constraintStart_toEndOf="@+id/quantity_input_layout">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/unit"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textCapWords" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/rate_layout"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginLeft="16dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginRight="8dp"
                            android:layout_marginBottom="25dp"
                            android:layout_weight="1"
                            android:hint="Rate (Price/Unit)*"
                            app:boxStrokeColor="@color/input_field_colors"
                            app:hintTextColor="@color/input_field_colors">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/rate"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/date_layout"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginLeft="8dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginRight="16dp"
                            android:layout_marginBottom="25dp"

                            android:layout_weight="1"
                            android:hint="Date"
                            app:boxStrokeColor="@color/input_field_colors"
                            app:hintTextColor="@color/input_field_colors"
                            app:layout_constraintStart_toEndOf="@+id/quantity_input_layout">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/trade_date"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="date" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>


                </LinearLayout>

            </FrameLayout>

            <FrameLayout

                android:id="@+id/data_input_panel_2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/white_sqaure_round"
                android:elevation="6dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/data_input_panel_1"
                app:layout_constraintVertical_bias="0.0">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <FrameLayout

                            android:id="@+id/subtotal_text_framlayout"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginStart="16dp"
                            android:layout_marginLeft="16dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginEnd="6dp"
                            android:layout_marginRight="8dp"
                            android:layout_weight="1"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/data_input_panel_1"
                            app:layout_constraintVertical_bias="0.0">

                            <TextView

                                android:id="@+id/subtotal_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:paddingTop="8dp"
                                android:paddingBottom="8dp"
                                android:text="Subtotal"
                                android:textColor="#7F8081"
                                android:textSize="17sp" />

                            <TextView

                                android:id="@+id/subtotal_sub_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:layout_marginLeft="66dp"
                                android:paddingTop="8dp"
                                android:paddingBottom="8dp"
                                android:text=" (Rate x Qty)"
                                android:textColor="#A4A9A9"
                                android:textSize="12sp" />
                        </FrameLayout>


                        <FrameLayout

                            android:id="@+id/subtotal_framlayout"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginStart="6dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginEnd="6dp"
                            android:layout_marginRight="8dp"
                            android:layout_weight="2"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/data_input_panel_1"
                            app:layout_constraintVertical_bias="0.0">

                            <TextView
                                android:id="@+id/textView5"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="left|center_vertical"
                                android:layout_marginLeft="1dp"

                                android:text="₹"
                                android:textSize="17sp" />


                            <TextView

                                android:id="@+id/subtotal"
                                android:layout_width="101dp"
                                android:layout_height="match_parent"
                                android:layout_gravity="right"
                                android:layout_marginLeft="6dp"
                                android:layout_marginRight="16dp"
                                android:backgroundTint="#F6F7FA"
                                android:ems="10"
                                android:gravity="left|center_vertical"
                                android:inputType="number"
                                android:paddingLeft="20dp"
                                android:paddingTop="8dp"
                                android:paddingRight="20dp"
                                android:paddingBottom="8dp"
                                android:textSize="17sp" />
                        </FrameLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <TextView

                            android:id="@+id/discount_text"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginLeft="16dp"
                            android:layout_marginTop="13.3dp"
                            android:layout_marginRight="8dp"
                            android:layout_weight="1"
                            android:foregroundGravity="bottom"
                            android:gravity="center_vertical"
                            android:paddingTop="8dp"
                            android:paddingRight="20dp"
                            android:paddingBottom="8dp"
                            android:text="Discount"
                            android:textColor="#7F8081"
                            android:textSize="17sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/discount_in_percent_layout"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginLeft="16dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginRight="8dp"
                            android:layout_weight="1.2"
                            android:hint="%"
                            app:boxStrokeColor="@color/input_field_colors"
                            app:hintTextColor="@color/input_field_colors"
                            app:layout_constraintStart_toEndOf="@+id/quantity_input_layout">


                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/discount_in_percent"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="right|center_vertical"

                                android:inputType="numberDecimal" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/discount_in_rupee_layout"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginLeft="8dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginRight="16dp"
                            android:layout_weight="1"
                            android:hint="₹"
                            app:boxStrokeColor="@color/input_field_colors"
                            app:hintTextColor="@color/input_field_colors">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/discount_in_rupee"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="left|center_vertical"

                                android:inputType="numberDecimal" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <TextView

                            android:id="@+id/gst_text"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginLeft="16dp"
                            android:layout_marginTop="13.3dp"
                            android:layout_marginRight="8dp"
                            android:layout_weight="1"
                            android:foregroundGravity="bottom"
                            android:gravity="center_vertical"
                            android:paddingTop="8dp"
                            android:paddingRight="20dp"
                            android:paddingBottom="8dp"
                            android:text="GST"
                            android:textColor="#7F8081"
                            android:textSize="17sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/gst_in_percent_layout"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginLeft="16dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginRight="8dp"
                            android:layout_weight="1.2"
                            android:hint="%"
                            app:boxStrokeColor="@color/input_field_colors"
                            app:hintTextColor="@color/input_field_colors"
                            app:layout_constraintStart_toEndOf="@+id/quantity_input_layout">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/gst_in_percent"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="right|center_vertical"

                                android:inputType="numberDecimal" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/gst_in_rupee_layout"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_marginLeft="8dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginRight="16dp"
                            android:layout_weight="1"
                            android:hint="₹"
                            app:boxStrokeColor="@color/input_field_colors"
                            app:hintTextColor="@color/input_field_colors">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/gst_in_rupee"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="left|center_vertical"
                                android:inputType="numberDecimal" />

                        </com.google.android.material.textfield.TextInputLayout>


                    </LinearLayout>


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <TextView

                            android:id="@+id/total_amount_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="16dp"
                            android:layout_marginTop="9.3dp"
                            android:layout_marginRight="8dp"
                            android:layout_weight="1"
                            android:foregroundGravity="bottom"
                            android:gravity="center_vertical"
                            android:paddingTop="8dp"
                            android:paddingRight="20dp"
                            android:paddingBottom="8dp"
                            android:text="Final Amount"
                            android:textColor="#7F8081"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <FrameLayout

                            android:id="@+id/total_amount_framlayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_marginLeft="16dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginEnd="6dp"
                            android:layout_marginRight="8dp"
                            android:layout_weight="2"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/data_input_panel_1"
                            app:layout_constraintVertical_bias="0.0">

                            <TextView
                                android:id="@+id/rupee99"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="left"
                                android:layout_marginLeft="1dp"
                                android:layout_marginTop="7dp"
                                android:gravity="left"
                                android:text="₹"
                                android:textSize="17sp" />


                            <TextView
                                android:id="@+id/dashes13"
                                android:layout_width="match_parent"
                                android:layout_height="20dp"
                                android:layout_gravity="right"
                                android:layout_marginTop="11dp"
                                android:layout_marginRight="16dp"
                                android:gravity="right"
                                android:text="_ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ "
                                android:textSize="17sp" />

                            <EditText

                                android:id="@+id/total_amount"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_gravity="right"
                                android:layout_marginLeft="6dp"
                                android:layout_marginRight="16dp"
                                android:backgroundTint="#00F6F7FA"
                                android:ems="10"

                                android:gravity="right"
                                android:inputType="number"
                                android:paddingLeft="20dp"
                                android:paddingTop="8dp"
                                android:paddingRight="20dp"
                                android:paddingBottom="8dp"
                                android:textSize="17sp" />
                        </FrameLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:paddingTop="7dp">

                        <CheckBox

                            android:id="@+id/payment_checkbox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:layout_marginTop="5dp"
                            android:layout_weight="1"
                            android:text="Payment"
                            android:textColor="#7F8081"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <FrameLayout

                            android:id="@+id/payment_amount_framelayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_marginLeft="16dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginEnd="6dp"
                            android:layout_marginRight="8dp"
                            android:layout_weight="2"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/data_input_panel_1"
                            app:layout_constraintVertical_bias="0.0">

                            <TextView
                                android:id="@+id/rupee9999"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="left"
                                android:layout_marginLeft="1dp"
                                android:layout_marginTop="7dp"
                                android:gravity="left"
                                android:text="₹"
                                android:textSize="17sp" />


                            <TextView
                                android:id="@+id/dashes133"
                                android:layout_width="match_parent"
                                android:layout_height="20dp"
                                android:layout_gravity="right"
                                android:layout_marginTop="11dp"
                                android:layout_marginRight="16dp"
                                android:gravity="right"
