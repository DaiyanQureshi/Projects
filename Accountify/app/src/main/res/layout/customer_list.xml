<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/manage_stock_list"
    android:backgroundTint="#FFFFFF"> <!-- Changed to wrap_content to fit the item -->

    <!-- This ImageView acts as the rounded rectangle background -->

    <!-- Product Image (DP) -->

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/dp"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:foregroundGravity="center_vertical"
        android:padding="2dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/Circular"
        app:srcCompat="@drawable/default_contect_logo" /> <!-- Added tools:srcCompat for preview -->

    <!-- "Purchase Price" Label (Top Right) -->
    <!-- This view is constrained to the end of the parent -->

    <TextView
        android:id="@+id/payable_or_receivable_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:gravity="end"
        android:text="Payable"
        android:textColor="#DB5555"
        android:textSize="12sp"
        app:layout_constraintBottom_toTopOf="@+id/payable_or_receivable"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/dp"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- "50 Bags" Value (Bottom Right) -->
    <!-- This view is aligned to the start/end of its label above -->
    <TextView
        android:id="@+id/payable_or_receivable"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="right"
        android:text="₹ 50,000"
        android:textColor="#DB5555"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/dp"
        app:layout_constraintEnd_toEndOf="@+id/payable_or_receivable_text"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="@+id/payable_or_receivable_text"
        app:layout_constraintTop_toBottomOf="@+id/payable_or_receivable_text" />

    <!-- "Dairy Milk" Title (Top Left) -->
    <!-- Width is 0dp to fill space between image and price text -->

    <!-- "Qty: 120 Barrs" (Bottom Left) -->
    <!-- Aligned to the Title's start/end to fill the same space -->
    <TextView
        android:id="@+id/Name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="16dp"
        android:shadowColor="#404040"
        android:text="Rajiv Malik"
        android:textAppearance="@style/TextAppearance.AppCompat.Medium"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/due_date"
        app:layout_constraintEnd_toStartOf="@+id/payable_or_receivable_text"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@+id/dp"
        app:layout_constraintTop_toTopOf="@+id/dp"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/due_date"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Due Date: 12 Sep."
        android:textColor="#817E7E"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@+id/dp"
        app:layout_constraintEnd_toEndOf="@+id/person_type"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@+id/Name"
        app:layout_constraintTop_toBottomOf="@+id/Name" />

    <TextView
        android:id="@+id/person_type"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="#817E7E"
        android:textSize="10sp"
        app:layout_constraintBottom_toBottomOf="@+id/Name"
        app:layout_constraintEnd_toStartOf="@+id/payable_or_receivable_text"
        app:layout_constraintStart_toEndOf="@+id/Name"
        app:layout_constraintTop_toTopOf="@+id/Name" />

</androidx.constraintlayout.widget.ConstraintLayout>
