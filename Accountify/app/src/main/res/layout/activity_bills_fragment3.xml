<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F7"
    tools:context=".fragment_bills.Bills_fragment_3">

    <FrameLayout
        android:id="@+id/header_background"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:background="@drawable/header_background"
        android:elevation="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/sales"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="left"
            android:layout_marginLeft="18.6dp"
            android:layout_marginTop="17.3dp"
            android:gravity="start"
            android:text="Create Invoice"
            android:textColor="#304FFE"
            android:textSize="19sp"
            android:textStyle="bold" />

        <View
            android:layout_width="52.5dp"
            android:layout_height="2dp"
            android:layout_gravity="bottom|left"
            android:layout_marginLeft="16.5dp"
            android:layout_marginBottom="2dp"
            android:background="#304FFE"
            android:visibility="gone" />

        <TextView
            android:id="@+id/purchase"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="left"
            android:layout_marginLeft="94.6dp"
            android:layout_marginTop="17.3dp"
            android:gravity="start"
            android:text="Purchases"
            android:textColor="#7F8081"
            android:textSize="19sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <View
            android:layout_width="96.7dp"
            android:layout_height="2dp"
            android:layout_gravity="bottom|left"
            android:layout_marginLeft="92.5dp"
            android:layout_marginBottom="2dp"
            android:background="#304FFE"
            android:visibility="gone" />

        <TextView
            android:id="@+id/quatations"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="left"
            android:layout_marginLeft="212.6dp"
            android:layout_marginTop="17.3dp"
            android:gravity="start"
            android:text="Quotations"
            android:textColor="#7F8081"
            android:textSize="19sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <View
            android:layout_width="98.7dp"
            android:layout_height="2dp"
            android:layout_gravity="bottom|left"
            android:layout_marginLeft="210.5dp"
            android:layout_marginBottom="2dp"
            android:background="#304FFE"
            android:visibility="gone" />

        <SearchView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|end"
            android:layout_marginTop="2.5dp"
            android:layout_marginRight="37dp"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/three_dots"
            android:layout_width="37dp"
            android:layout_height="24dp"
            android:layout_gravity="end"
            android:layout_marginTop="19dp"
            android:layout_marginRight="2.7dp"
            android:onClick="threedots"
            android:visibility="gone"
            app:srcCompat="@drawable/three_dots" />
    </FrameLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/bills_recycle_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header_background" />

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:textColor="#FFFFFF"
        app:backgroundTint="#304FFE"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.833"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.85" />

</androidx.constraintlayout.widget.ConstraintLayout>