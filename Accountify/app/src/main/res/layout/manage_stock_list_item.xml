<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/selectable_item_background"> <!-- Changed to wrap_content to fit the item -->

    <!-- This ImageView acts as the rounded rectangle background -->

    <!-- Product Image (DP) -->

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/dp"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:foregroundGravity="center_vertical"
        android:padding="2dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/Circular"
        app:srcCompat="@drawable/product_icon" /> <!-- Added tools:srcCompat for preview -->

    <!-- "Purchase Price" Label (Top Right) -->
    <!-- This view is constrained to the end of the parent -->

    <TextView
        android:id="@+id/payable_or_receivable_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:gravity="end"
        android:text="Purchase Price"
        android:textColor="#817E7E"
        android:textSize="12sp"
        app:layout_constraintBottom_toTopOf="@+id/payable_or_receivable"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/dp"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- "50 Bags" Value (Bottom Right) -->
    <!-- This view is aligned to the start/end of its label above -->
    <TextView
        android:id="@+id/payable_or_receivable"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="right"
        android:text="₹ 9,989.00"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/dp"
        app:layout_constraintEnd_toEndOf="@+id/payable_or_receivable_text"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="@+id/payable_or_receivable_text"
        app:layout_constraintTop_toBottomOf="@+id/payable_or_receivable_text" />

    <!-- "Dairy Milk" Title (Top Left) -->
    <!-- Width is 0dp to fill space between image and price text -->

    <!-- "Qty: 120 Barrs" (Bottom Left) -->
    <!-- Aligned to the Title's start/end to fill the same space -->
    <TextView
        android:id="@+id/Name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="16dp"
        android:shadowColor="#404040"
        android:text="Dairy Milk"
        android:textAppearance="@style/TextAppearance.AppCompat.Medium"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/avg_rate"
        app:layout_constraintEnd_toStartOf="@+id/payable_or_receivable_text"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@+id/dp"
        app:layout_constraintTop_toTopOf="@+id/dp"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/avg_rate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Rate: 5000 ₹/Cts."
        android:textColor="#817E7E"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@+id/dp"
        app:layout_constraintEnd_toEndOf="@+id/Name"
        app:layout_constraintStart_toStartOf="@+id/Name"
        app:layout_constraintTop_toBottomOf="@+id/Name"
        app:layout_constraintVertical_bias="0.0" />

    <com.google.android.material.card.MaterialCardView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
     app:strokeWidth="0dp" app:cardBackgroundColor="#D5EDDC" app:cardElevation="0dp" app:layout_constraintBottom_toTopOf="@+id/payable_or_receivable_text"
    app:layout_constraintEnd_toEndOf="parent"
    app:shapeAppearanceOverlay="@style/CustomCardShape"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintVertical_bias="0.0">

        <TextView
            android:id="@+id/total_quantity"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingLeft="15dp"
            android:paddingTop="1.5dp"
            android:paddingRight="13dp"
            android:paddingBottom="2dp"
            android:text="Qty: 49.00 Cts."
            android:textColor="#064F23"
            android:textSize="10.7sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/payable_or_receivable_text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.0" />

</com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>
